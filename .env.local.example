# ============================================================
# Google reviews (live star rating + review count)
# ============================================================
# Copy this file to `.env.local` and fill in both values.
# Until both are set, the site falls back to the values in
# src/lib/config.ts (googleRating / googleReviewCount).
#
# 1) GOOGLE_PLACES_API_KEY
#    Google Cloud Console -> create/select a project -> enable
#    "Places API (New)" -> Credentials -> create an API key.
#    (Restrict the key to the Places API.) Billing must be enabled,
#    but with 24h caching this stays within the free tier.
#
# 2) GOOGLE_PLACE_ID
#    The shop's Place ID (NOT the CID/short URL). Find it with
#    Google's Place ID Finder:
#    https://developers.google.com/maps/documentation/places/web-service/place-id

GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
